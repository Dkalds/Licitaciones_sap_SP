# Variables de entorno — copia este archivo como .env y rellena los valores
# NUNCA commitees .env al repositorio

# ── Base de datos ──────────────────────────────────────────────────────
# Opción A: SQLite local (por defecto, sin configuración adicional)
# DB_PATH=data/licitaciones.db

# Opción B: Turso cloud (ambas variables son obligatorias si se usa Turso)
# TURSO_DATABASE_URL=libsql://<tu-db>.<region>.turso.io
# TURSO_AUTH_TOKEN=<jwt-token-con-permisos-rw>

# Ruta del archivo de réplica local de Turso (opcional, default: data/licitaciones_replica.db)
# TURSO_LOCAL_DB=data/licitaciones_replica.db

# ── Dashboard ─────────────────────────────────────────────────────────
# Contraseña para proteger el dashboard. Dejar vacío para deshabilitar autenticación.
# DASHBOARD_PASSWORD=cambia-esto-por-una-contraseña-segura

# ── Rutas (opcionales) ────────────────────────────────────────────────
# DATA_DIR=data
